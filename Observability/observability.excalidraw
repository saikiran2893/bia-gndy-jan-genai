    {
      "id": "7lF9ok7FdCM8Bini50WHf",
      "type": "text",
      "x": 239,
      "y": 485,
      "width": 851.7794189453125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 131367249,
      "version": 394,
      "versionNonce": 1819772639,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780110280655,
      "link": null,
      "locked": false,
      "text": "-> Non-deterministic Behaviour\n-> Reasoning Chains -> Visibility of tool calling\n-> Drift -> Model can get update, Prompt can get drift and API may not work properly\n-> Cost -> For monitoring tokens and usage\n-> Debugging Hallucinations -> Agents not working as per the script\n-> Confidence -> Proving to Stakeholders that system is behaivng coreectly with data ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> Non-deterministic Behaviour\n-> Reasoning Chains -> Visibility of tool calling\n-> Drift -> Model can get update, Prompt can get drift and API may not work properly\n-> Cost -> For monitoring tokens and usage\n-> Debugging Hallucinations -> Agents not working as per the script\n-> Confidence -> Proving to Stakeholders that system is behaivng coreectly with data ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qf2lTdykIzCpGOisirju3",
      "type": "text",
      "x": 258.625,
      "y": 702.65625,
