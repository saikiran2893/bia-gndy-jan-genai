    {
      "id": "WSlWZe2MR0HzpaOq5Psv1",
      "type": "text",
      "x": 307,
      "y": 952,
      "width": 833.0194091796875,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
