      "seed": 2004126751,
      "version": 517,
      "versionNonce": 1731326495,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780111140893,
      "link": null,
      "locked": false,
      "text": "- It is langchain for LLm app and Agents\n- It is a both evaluation and observability took\n- It is easy to configure , we can configure multiple environments\n- Traces: LLM Call, Tool Execution, Actions etc\n- Prompt Version: Compare various prompt runs that affect output quality.\n- Evaluation Pipelines : You can run automated evaluations to catch regressor\n- Free and it has subscription based -> Free for small workloads, class room trainings\n\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- It is langchain for LLm app and Agents\n- It is a both evaluation and observability took\n- It is easy to configure , we can configure multiple environments\n- Traces: LLM Call, Tool Execution, Actions etc\n- Prompt Version: Compare various prompt runs that affect output quality.\n- Evaluation Pipelines : You can run automated evaluations to catch regressor\n- Free and it has subscription based -> Free for small workloads, class room trainings\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
