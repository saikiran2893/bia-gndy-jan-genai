      "updated": 1781323800339,
      "link": null,
      "locked": false,
      "text": "Various libraries that support TTS:\n\n1. pyttsx3 -> Low cost, low quality for POC and edges devices\n2. Google Cloud TTS -> Very good, Paid, Production apps\n3. Open AI TTS -> Excellent, paid, Natural conversation\n4. cartesia -> Excellent, Paid, natural languages(Real - time voice agents)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Various libraries that support TTS:\n\n1. pyttsx3 -> Low cost, low quality for POC and edges devices\n2. Google Cloud TTS -> Very good, Paid, Production apps\n3. Open AI TTS -> Excellent, paid, Natural conversation\n4. cartesia -> Excellent, Paid, natural languages(Real - time voice agents)",
      "autoResize": true,
      "lineHeight": 1.25
    }
