      "seed": 1521280035,
      "version": 513,
      "versionNonce": 5070349,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781322917679,
      "link": null,
      "locked": false,
      "text": "TTS: Text to Speech:\n\nEvery Text has to undergo lingusitic analysis\n1. Dr. will be told as Doctor\n2. numbers should be spelled out\n3. Then it has be tagged to the Part of speech\n4. Which syllabes to be stressed\n5. It converts into the building block of sounds\n6. It adds, rythms, pitch and pauses.\n7. It makes speech more natural than robotic\n8. All these will be converted to wav format(with help of deep learning model or AI models)\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TTS: Text to Speech:\n\nEvery Text has to undergo lingusitic analysis\n1. Dr. will be told as Doctor\n2. numbers should be spelled out\n3. Then it has be tagged to the Part of speech\n4. Which syllabes to be stressed\n5. It converts into the building block of sounds\n6. It adds, rythms, pitch and pauses.\n7. It makes speech more natural than robotic\n8. All these will be converted to wav format(with help of deep learning model or AI models)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
