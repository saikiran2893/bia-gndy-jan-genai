    {
      "id": "5x-ukO73TeavO7bWurzC5",
      "type": "text",
      "x": 109,
      "y": 2573,
      "width": 596.959716796875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
