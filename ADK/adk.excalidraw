      "isDeleted": false,
      "boundElements": null,
      "updated": 1779505308948,
      "link": null,
      "locked": false,
      "text": "Memory - Long term memory that spans multiple sessions\nRunner - Engine that orchestrate the Agent\nEvent - A unit of communication - input, llm, tools, tool result",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Memory - Long term memory that spans multiple sessions\nRunner - Engine that orchestrate the Agent\nEvent - A unit of communication - input, llm, tools, tool result",
      "autoResize": true,
