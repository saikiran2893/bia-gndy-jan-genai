      "isDeleted": false,
      "boundElements": null,
      "updated": 1779510421964,
      "link": null,
      "locked": false,
      "text": "There will be determinstic Orchestrator\nThey will control the execution of the order instead of LLM ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There will be determinstic Orchestrator\nThey will control the execution of the order instead of LLM ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Cr1AONpJAVmeS4TSojD3w",
      "type": "text",
      "x": 67,
      "y": 2695,
      "width": 453.6197509765625,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 586081563,
      "version": 171,
      "versionNonce": 1882693653,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779510479667,
      "link": null,
      "locked": false,
      "text": "3 types:\n\n1. Sequential : A-> B-> C\n2. Parallel -> A+B+C at same time\n3. Loop -> Execute until some condiiton is met\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3 types:\n\n1. Sequential : A-> B-> C\n2. Parallel -> A+B+C at same time\n3. Loop -> Execute until some condiiton is met\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_nyhkIol-7z8pUTQmgxq9",
      "type": "text",
      "x": 53.3515625,
      "y": 2891.7421875,
      "width": 310.1796875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
