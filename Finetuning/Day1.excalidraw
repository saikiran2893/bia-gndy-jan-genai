      "seed": 1556009574,
      "version": 343,
      "versionNonce": 1687080122,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774065403566,
      "link": null,
      "locked": false,
      "text": "-> Bias : Identify and make sure you pass correct data for fine-tuning\n-> Untruthfull and unfaithfullness data : to avoid hallucinations\n-> Make sure model doesn't undergo jailbreak\n-> Mistake to avoid \n1. Evaluation is must\n2. OVerfitting\n3. Skipping regression testing",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> Bias : Identify and make sure you pass correct data for fine-tuning\n-> Untruthfull and unfaithfullness data : to avoid hallucinations\n-> Make sure model doesn't undergo jailbreak\n-> Mistake to avoid \n1. Evaluation is must\n2. OVerfitting\n3. Skipping regression testing",
      "autoResize": true,
      "lineHeight": 1.25
    },
