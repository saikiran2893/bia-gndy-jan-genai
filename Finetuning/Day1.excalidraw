      "type": "text",
      "x": -222.7768739135372,
      "y": 3485.070821773927,
      "width": 691.739501953125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
