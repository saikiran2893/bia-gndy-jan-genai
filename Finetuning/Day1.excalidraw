      "updated": 1774061900370,
      "link": null,
      "locked": false,
      "text": "Pretraining -> This is very costly\nFUll Finetuning -> 50%\nPEFT Finetuning -> 10-30%\nRAG -> 5%\nPrompt ->1%",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pretraining -> This is very costly\nFUll Finetuning -> 50%\nPEFT Finetuning -> 10-30%\nRAG -> 5%\nPrompt ->1%",
      "autoResize": false,
      "lineHeight": 1.25
