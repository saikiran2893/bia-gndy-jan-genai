    {
      "id": "xNR0LEhBljc8RLbJtrAUk",
      "type": "text",
      "x": 302.11582985466976,
      "y": 2780.574512664913,
      "width": 1438.27880859375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 2014154495,
      "version": 402,
      "versionNonce": 310016081,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780721946562,
      "link": null,
      "locked": false,
      "text": "Healthcare -> AI reads scans or MRI and flags the high risk patient. But have a radilogist reveiw it on its domain expret to take correct decision.\n\n Finance -> AI decides loan approval, credit score etc has to be explained to regulatory before been used in the banking \n\nHR -> Bias and Fairness been to enforce in the Screening tools\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Healthcare -> AI reads scans or MRI and flags the high risk patient. But have a radilogist reveiw it on its domain expret to take correct decision.\n\n Finance -> AI decides loan approval, credit score etc has to be explained to regulatory before been used in the banking \n\nHR -> Bias and Fairness been to enforce in the Screening tools\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zQzF7xwzdSXhxBcv9rZ81",
      "type": "text",
      "x": 252.1158298546694,
      "y": 2965.2683902159465,
      "width": 650.1195678710938,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aV",
      "roundness": null,
      "seed": 368059825,
      "version": 255,
      "versionNonce": 1079016447,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780723230960,
      "link": null,
      "locked": false,
      "text": "Human In the Loop:\n\n-> Human in the loop -> AI -> Human Reviews it -> User -> Low\n-> Human on the loop -> AI -> ROuter -> Automatically or Manually\n-> Human in Command -> AI -> Human Decides -> AI Action -> High",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Human In the Loop:\n\n-> Human in the loop -> AI -> Human Reviews it -> User -> Low\n-> Human on the loop -> AI -> ROuter -> Automatically or Manually\n-> Human in Command -> AI -> Human Decides -> AI Action -> High",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
