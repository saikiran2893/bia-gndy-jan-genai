    {
      "id": "dx2OnnR06UCpzf-Q5mFq4",
      "type": "text",
      "x": -162,
      "y": 4536,
      "width": 642.27294921875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
