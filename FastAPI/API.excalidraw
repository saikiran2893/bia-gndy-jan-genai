      "isDeleted": false,
      "boundElements": null,
      "updated": 1778300727814,
      "link": null,
      "locked": false,
      "text": "Streaming Responses:\n\n-> It is very much essential for AI application.\n-> Instead of waiting full responses , you stream tokens as they arrive\n\nTwo formats:\n1. Plain text stream\n2. Server sent Stream\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Streaming Responses:\n\n-> It is very much essential for AI application.\n-> Instead of waiting full responses , you stream tokens as they arrive\n\nTwo formats:\n1. Plain text stream\n2. Server sent Stream\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
