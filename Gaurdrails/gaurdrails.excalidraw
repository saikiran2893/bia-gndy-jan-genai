      "boundElements": null,
      "updated": 1780237495329,
      "link": null,
      "locked": false,
      "text": "Failure Modes Gaurdrails can prevent:\n\n-> Data Leakage - Users try to extract sensitive information from the context.\n-> harmful output - Avoiding model produces dangerous ,illelegal context as output\n-> Agent Misuse - Agent system takes unauthroised actions, we can prevent it.\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Failure Modes Gaurdrails can prevent:\n\n-> Data Leakage - Users try to extract sensitive information from the context.\n-> harmful output - Avoiding model produces dangerous ,illelegal context as output\n-> Agent Misuse - Agent system takes unauthroised actions, we can prevent it.\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
